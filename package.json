{
  "name": "stream-deck-ai-stats",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "test": "node --test test/*.test.js",
    "check": "node --check src/core/*.js && node --check src/stream-deck/*.js",
    "bundle": "node scripts/bundle-plugin.mjs",
    "validate:plugin": "node scripts/validate-plugin.mjs",
    "verify": "npm run check && npm test && npm run bundle && npm run validate:plugin",
    "package": "npm run verify && node scripts/package-plugin.mjs"
  }
}
